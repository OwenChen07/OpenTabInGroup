{
  "manifest_version": 3,
  "name": "Tabby",
  "version": "1.0",
  "description": "Tools for managing tabs in Chrome",
  "permissions": ["tabGroups", "storage"],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "commands": {
    "open-tab-in-same-group": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "Open a new tab inside the current tab group"
    },
    "switch-to-left-tab": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Switch to the tab on the left"
    },
    "switch-to-right-tab": {
      "suggested_key": {
        "default": "Alt+D",
        "mac": "Alt+D"
      },
      "description": "Switch to the tab on the right"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}